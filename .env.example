# =============================================================================
# OmniDiff - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://omnidiff:omnidiff@localhost:5432/omnidiff

# --- Embedding Provider ------------------------------------------------------
# Options: voyage | gemini
# Voyage AI (recommended): 200M free tokens/month — https://dash.voyageai.com/
# Gemini: free tier available — https://aistudio.google.com/apikey
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-code-3

# --- LLM Provider (interactive RAG) -----------------------------------------
# Options: gemini | groq | openai
# Gemini: free tier or Pro plan — https://aistudio.google.com/apikey
# Groq: 14.4K req/day free — https://console.groq.com/keys
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# --- LLM Batch Provider (NL descriptions of diffs) --------------------------
# Options: groq | gemini
# Groq recommended for batch: fast + free
LLM_BATCH_PROVIDER=groq
LLM_BATCH_MODEL=llama-3.1-8b-instant

# --- API Keys ----------------------------------------------------------------
VOYAGE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Application -------------------------------------------------------------
APP_VERSION=0.1.0
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
